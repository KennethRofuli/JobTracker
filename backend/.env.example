# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/job-tracker

# Session settings
SESSION_SECRET=your-session-secret
CLIENT_URL=http://localhost:3000
COOKIE_DOMAIN=localhost

# Email notification settings
# Use the SendGrid Web API for email delivery.
# Recommended for Render and other cloud hosts.
# SENDGRID_API_KEY=SG.xxxxxxxx
# EMAIL_FROM="Job Tracker <jobtracker.notify@gmail.com>"
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM="Job Tracker <no-reply@example.com>"

# Optional SMTP fallback (not used by default)
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=false
# EMAIL_SMTP_USER=your-smtp-user
# EMAIL_SMTP_PASS=your-smtp-password
# EMAIL_FROM="Job Tracker <no-reply@example.com>"

# Scheduler settings
DAILY_SUMMARY_CRON=0 8 * * *
FOLLOW_UP_CRON=0 9 * * *
SCHEDULER_TIMEZONE=UTC
